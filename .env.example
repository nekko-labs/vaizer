# All of these are OPTIONAL. The site builds and runs without any of them.

# Absolute site URL, used for metadata / canonical / OG.
NEXT_PUBLIC_SITE_URL=https://vaizer.com

# Discord invite link: target of the community CTA.
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/nekkolabs

# GitHub repo link shown in the header/footer.
NEXT_PUBLIC_GITHUB_URL=https://github.com/nekko-labs/vaizer

# Supabase: powers skill upvotes + feedback. Inert (votes read as 0) when unset.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only salt for hashing voter fingerprints.
VOTE_SALT=

# PostHog product analytics: disabled when unset. Respects Do Not Track.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
